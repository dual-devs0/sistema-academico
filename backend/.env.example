DATABASE_URL=sqlite:///./sistema_academico.db

JWT_SECRET=cambiar-por-un-valor-seguro-de-32-chars
JWT_EXPIRES_MINUTES=480

# Cookies de refresh/csrf con flag Secure (requiere HTTPS). Default true.
# Bajar a false SOLO en dev local sobre http://localhost — nunca en producción.
COOKIE_SECURE=true

# Comma-separated list of allowed frontend origins.
# In production, replace with the real domain: https://sistema.uca.edu.py
CORS_ORIGINS=http://localhost:5173

# Configuración de fastapi-mail para Notificaciones
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=tu_contraseña_de_aplicacion
MAIL_FROM=sistema@uca.edu.py
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=True
MAIL_SSL_TLS=False
USE_CREDENTIALS=True
VALIDATE_CERTS=True

# Stripe — Pagos Online
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# Facturación electrónica (Fase 4B) — guarani.app
# Sin estas credenciales, la emisión de comprobantes degrada con gracia:
# el pago se registra igual y el comprobante queda en estado 'error',
# reintentable, sin bloquear al alumno.
GUARANI_APP_API_KEY=
GUARANI_APP_PUNTO_EMISION=
GUARANI_APP_BASE_URL=https://api.guarani.app/v1

# Web Push VAPID keys (se autogeneran si están vacías)
VAPID_PUBLIC_KEY=BP_placeholder
VAPID_PRIVATE_KEY=placeholder
VAPID_CLAIM_EMAIL=admin@uca.edu.py

# Cloudflare R2 (o cualquier storage S3-compatible) — fotos de perfil, apuntes,
# comprobantes, informes de pasantía. Sin esto, las subidas de archivo fallan.
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=uca-v2-storage
