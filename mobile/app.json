{
  "expo": {
    "name": "UCA Móvil",
    "slug": "uca-movil",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "ucamovil",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#1a3569",
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "py.edu.uca.movil",
      "infoPlist": {
        "NSCameraUsageDescription": "Se requiere la cámara para escanear el código QR de asistencia.",
        "NSFaceIDUsageDescription": "Se usa Face ID para autenticación biométrica."
      }
    },
    "android": {
      "package": "py.edu.uca.movil",
      "adaptiveIcon": {
        "backgroundColor": "#1a3569",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Se requiere la cámara para escanear el código QR de asistencia."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Se usa Face ID para autenticación biométrica."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1a3569",
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
