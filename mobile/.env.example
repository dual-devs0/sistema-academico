# Configuración de la app móvil UCA
#
# Copiá este archivo como .env y ajustá las variables según tu entorno.
# Las variables de entorno tienen prioridad sobre app.json.

# URL base de la API del backend.
# Ejemplos:
#   http://localhost:8000          — desarrollo local (emulador)
#   http://192.168.1.100:8000      — desarrollo con IP local
#   https://api.uca.edu.py         — producción
EXPO_PUBLIC_API_URL=http://localhost:8000
