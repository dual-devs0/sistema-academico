# ============================================================
# SISTEMA ACADÉMICO - Variables de entorno
# Copiar este archivo como .env y completar los valores
# NUNCA subir el archivo .env al repositorio
# ============================================================

# Base de datos PostgreSQL
DATABASE_URL="postgresql://usuario:contraseña@localhost:5432/sistema_academico"

# Autenticación JWT
JWT_SECRET="cambiar_por_una_clave_secreta_larga_y_aleatoria"
JWT_EXPIRES_IN="8h"
JWT_REFRESH_EXPIRES_IN="7d"

# Servidor backend
PORT=3001
NODE_ENV=development

# Frontend (Vite)
VITE_API_URL=http://localhost:3001/api/v1

# Supabase (opcional - para storage de apuntes)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Email (Resend)
RESEND_API_KEY=

# Google Gemini (para parseo de PDF del calendario)
GEMINI_API_KEY=
